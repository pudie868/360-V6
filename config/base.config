# ============================================================
# 360 V6 专属编译配置 (修复 Exit Code 1 + IP 冲突)
# ============================================================

# 1️⃣ 必须有这前三行！这是解决 Exit code 1 的关键
# 如果缺少这三行，系统不知道为哪款路由器编译，直接报错
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y

# 2️⃣ 修改默认 IP 地址 (解决 IP 冲突)
# 将下面的配置项设为 192.168.2.1，覆盖默认的 192.168.1.1
CONFIG_TARGET_PREINIT_IP="192.168.2.1"
CONFIG_TARGET_PREINIT_BROADCAST="192.168.2.255"

# 3️⃣ 分区设置 (您的旧配置保留)
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=768

# 4️⃣ 镜像格式 (您的旧配置保留)
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y

# 5️⃣ 常用基础包 (必须包含，否则无法启动)
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_kmod-nft-offload=y

# 6️⃣ 360 V6 无线驱动 (必须包含)
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y

# 7️⃣ NSS 硬件加速驱动 (重要性能插件)
CONFIG_PACKAGE_kmod-qca-ssdk=y
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y

# 8️⃣ 后续按需添加其他插件...
# 例如 Docker, Passwall 等
