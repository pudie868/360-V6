# ============================================================
# 360 V6 稳定版配置 (修复网络启动问题)
# 修正：禁用 NSS 驱动，修复 DSA 网络架构
# ============================================================

# 1️⃣ 目标设备 (IPQ6018 架构)
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y

# 2️⃣ 镜像分区大小
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=512
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y

# 3️⃣ 网络预设 (避免与光猫 192.168.1.1 冲突)
CONFIG_TARGET_PREINIT_IP="192.168.2.1"
CONFIG_TARGET_PREINIT_BROADCAST="192.168.2.255"

# 4️⃣ ❌ 禁用 NSS 驱动 (与 DSA 冲突，会导致网络无法启动)
# 成功的案例没有使用 NSS 加速，依赖软件 offload
# CONFIG_PACKAGE_kmod-qca-ssdk is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv is not set
# CONFIG_PACKAGE_kmod-qca-nss-ecm is not set
# CONFIG_PACKAGE_kmod-fast-classifier is not set
# CONFIG_PACKAGE_kmod-shortcut-fe is not set

# 5️⃣ 无线驱动 (IPQ6018 专用固件，不是 QCN9074)
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y
# CONFIG_PACKAGE_ath11k-firmware-qcn9074 is not set

# 6️⃣ 核心网络 (Firewall4 + nftables，标准 DSA)
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_nftables=y
# CONFIG_PACKAGE_iptables-legacy is not set
CONFIG_PACKAGE_iptables-nft=y

# 7️⃣ ZRAM 内存优化 (使用系统自带方案，更稳定)
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y

# 8️⃣ 🐳 Docker 容器 (使用 nftables 后端，与 firewall4 兼容)
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-br-netfilter=y

# 9️⃣ 🛡️ AdGuardHome
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y
CONFIG_PACKAGE_adguardhome=y

# 🔟 🚀 HomeProxy 代理
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_kmod-tun=y
# CONFIG_PACKAGE_sing-box-tiny is not set  (必须禁用，防止冲突)

# 1️⃣1️⃣ ⚡ TurboAcc 加速 (软件加速，不使用 NSS)
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y
CONFIG_PACKAGE_kmod-tcp-bbr=y

# 1️⃣2️⃣ 🔗 Lucky 内网穿透
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-i18n-lucky-zh-cn=y
CONFIG_PACKAGE_lucky=y

# 1️⃣3️⃣ 📁 文件管理
CONFIG_PACKAGE_luci-app-filebrowser=y
CONFIG_PACKAGE_luci-i18n-filebrowser-zh-cn=y
CONFIG_PACKAGE_filebrowser=y

# 1️⃣4️⃣ 🖥️ 界面与中文
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# 1️⃣5️⃣ 💾 USB 与 存储支持
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_e2fsprogs=y

# 1️⃣6️⃣ 系统工具
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_vim-full=y

# 1️⃣7️⃣ 编译优化
CONFIG_CCACHE=y
