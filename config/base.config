# ========================================================================
# 360 V6 (IPQ6018) OpenWrt 23.05 专属编译配置
# 维护说明：此文件将直接覆盖至 OpenWrt 源码根目录的 .config
# ========================================================================

# ================== 1️⃣ 目标平台 ==================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y

# ================== 2️⃣ 镜像与分区设置 ==================
# 768MB 预留充足空间（代理规则/插件/Docker镜像），避免后期扩容麻烦
CONFIG_TARGET_ROOTFS_PARTSIZE=768
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# ================== 3️⃣ 核心冲突修复 ==================
# 【关键】显式禁用默认 dnsmasq，否则 dnsmasq-full 编译时会报文件冲突
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y

# ================== 4️⃣ 内存优化与 ZRAM ==================
# IPQ6018 通常为 512MB/1GB，ZRAM 可显著提升多代理/高并发稳定性
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y
# ZRAM 默认使用 zstd 压缩算法，需确保加密模块已启用
CONFIG_PACKAGE_kmod-crypto-zstd=y

# ================== 5️⃣ NSS 硬件加速 (QCA 网络子系统) ==================
# IPQ60xx 核心优势：通过 NSS 硬件卸载实现千兆 NAT/PPPoE 跑满 CPU
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y

# ⚠️ 桥接管理器：与 Docker veth 存在底层转发路径冲突
# 若启用下方，则必须禁用 Docker；若用 Docker，则保持下方注释
# CONFIG_PACKAGE_kmod-qca-nss-drv-bridge-mgr=y

# ================== 6️⃣ Docker 容器支持 (按需启用) ==================
# 【冲突原理】Docker 依赖 Linux 软件网桥(veth+br)进行 NAT/端口映射。
# NSS Bridge Manager 会劫持网桥流量走硬件转发，导致：
#   1. 容器端口映射失效 / 防火墙规则被绕过
#   2. 偶发丢包 / 容器无法访问外网
# 【策略】启用 Docker 时，保持 bridge-mgr 注释状态即可
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-nft-bridge=y

# ================== 7️⃣ 网络代理与科学上网 ==================
# Sing-Box 核心 + HomeProxy (现代化 LuCI 界面)
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_luci-app-homeproxy=y

# Passwall 核心 + LuCI 界面 + 完整中文语言包
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y

# ================== 8️⃣ 系统与网络优化 ==================
# BBR 拥塞控制算法（提升弱网/高延迟环境吞吐量）
CONFIG_PACKAGE_kmod-tcp-bbr=y

# nftables 硬件卸载支持（OpenWrt 23.05 默认防火墙）
CONFIG_PACKAGE_kmod-nft-offload=y

# IPv6 基础支持（按需）
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# ================== 9️⃣ 无线驱动 (WiFi6) ==================
# IPQ6018 内置 WiFi6 芯片驱动，通过 AHB 总线连接
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y

# ================== 🔟 界面与本地化 ==================
# LuCI 基础中文 + Argon 主题
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y

# ================== 1️⃣1️⃣ 基础工具 (按需增减) ==================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_bash=y
