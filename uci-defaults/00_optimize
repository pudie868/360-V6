#!/bin/sh
# ============================================================
# Performance Optimization (无 Heredoc 版)
# ============================================================

# 1. CPU 性能模式
for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    [ -f "$cpu" ] && echo "performance" > "$cpu"
done

# 2. ZRAM 配置 (优先 zstd)
if [ ! -b /dev/zram0 ]; then
    modprobe zram
    if grep -q "zstd" /sys/block/zram0/comp_algorithm 2>/dev/null; then
        echo zstd > /sys/block/zram0/comp_algorithm
    else
        echo lz4 > /sys/block/zram0/comp_algorithm
    fi
    echo 512M > /sys/block/zram0/disksize
    mkswap /dev/zram0
    swapon /dev/zram0 -p 5
fi

# 3. 系统参数优化 (使用 echo 逐行追加，避免 Heredoc)
SYSCTL_FILE="/etc/sysctl.conf"
echo "net.core.default_qdisc=fq" >> $SYSCTL_FILE
echo "net.ipv4.tcp_congestion_control=bbr" >> $SYSCTL_FILE
echo "net.ipv4.ip_forward=1" >> $SYSCTL_FILE
echo "net.core.rmem_max=16777216" >> $SYSCTL_FILE
echo "net.core.wmem_max=16777216" >> $SYSCTL_FILE

sysctl -p
exit 0
